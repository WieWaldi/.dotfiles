# +----------------------------------------------------------------------------+
# | ~/.gitconfig                                                               |
# +----------------------------------------------------------------------------+
# | Copyright © 2019 Waldemar Schroeer                                         |
# |                  waldemar.schroeer(at)rz-amper.de                          |
# +----------------------------------------------------------------------------+


[user]
    name = Waldemar Schröer
    email = w@ldemar.de

[github]
    user = WieWaldi

[init]
    defaultBranch = master

[help]
    autocorrect = prompt

[tag]
    sort = -version:refname

[column]
    ui = auto
    # status = auto
    # branch = auto
    # diff = auto
    # log = auto

[branch]
    sort = -committerdate

[pull]
    rebase = false

[core]
    editor = vim

[status]
    branch = true
    showUntrackedFiles = all
    showBranch = true
    showStash = true
    showIgnored = true
    showUnmerged = true
    showStaged = true
    showUnstaged = true

[commit]
    verbose = true

[push]
    default = simple

[diff]
    external = git-diff-wrapper.sh
    # algorithm = histogram
    # colorMoved = zebra
    # colorMovedWS = allow-indentation-change
    # context = 8
    # renames = copies
    # interHunkContext = 10

[pager]
    diff =

[color]
    ui = auto

[color "branch"]
    current = red
    local = yellow
    remote = blue

[color "status"]
    added = green
    changed = red
    untracked = yellow

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[alias]
    tree = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset%n' --abbrev-commit --date=relative --branches
    graph = "log --graph --all --format=format:'%C(blue)%h%C(reset) - %C(green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'"

